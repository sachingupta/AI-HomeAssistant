# Copy this file to .env and fill in your values
# .env is git-ignored — never commit it

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8080/oauth/callback
GOOGLE_REFRESH_TOKEN=your-refresh-token   # Run: python -m backend.auth.google_auth

# Data store backend:
#   sheets  — Google Sheets tabs (default; easy to inspect in browser during dev)
#   drive   — Google Drive JSON files (production)
#   mcp     — route all storage through the MCP server subprocess (JSON-RPC over stdio);
#             the MCP server itself uses DATA_STORE=drive
DATA_STORE=sheets
GOOGLE_SHEET_ID=1-MJDqHCOKUimFupFXJqA7KUwrGRDfhqPB3VnZWv0shs
DRIVE_FOLDER_ID=                          # Only needed when DATA_STORE=drive or mcp

FAMILY_NAME=Your Family Name

# Claude API
ANTHROPIC_API_KEY=your-anthropic-api-key

# FastAPI backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
