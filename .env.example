# Copy this file to .env and fill in your values
# .env is git-ignored — never commit it

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8080/oauth/callback
GOOGLE_REFRESH_TOKEN=your-refresh-token   # Run auth/google_auth.py once to generate this

# Google Drive folder ID for family storage
DRIVE_FOLDER_ID=1AY77PvZPwXZmnhI8egyLbIV7zK6_eAyh
FAMILY_NAME=Your Family Name

# Claude API
ANTHROPIC_API_KEY=your-anthropic-api-key

# FastAPI backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
